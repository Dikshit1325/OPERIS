{
    "manifest_version": 3,
    "name": "Operis Tracker",
    "version": "1.0",
    "permissions": ["tabs", "activeTab", "scripting"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html"
    },
    "host_permissions": ["http://127.0.0.1:8000/*"]
  }